      "title<.*messenger.*>": "ï‰ں",
      "title<.*facebook.*>": "ï‚ڑ ",
      "title<.*reddit.*>": "ïٹپ",
      "title<.*ChatGPT.*>": "َ°ڑ©",
      "class<.*ChatGPT.*>": "َ°ڑ©",
      "title<.*deepseek.*>": "َ°ڑ©",
      "title<.*qwen.*>": "َ°ڑ©",
      "class<subl>": "َ°…³",
      "class<slack>": "ï†ک",
      "class<mpv>": "ïچ®",
      "class<celluloid|Zoom>": "ï€½",
      "class<Cider>": "َ°ژ† ",
      "title<.*Picture-in-Picture.*>": "ï”¬",
      "title<.*youtube.*>": "ï…ھ",
      "class<vlc>": "َ°•¼",
      "title<.*cmus.*>": "ï€پ",
      "class<[Ss]potify>": "ï†¼",
      "class<virt-macodeger>": "î­»",
      "class<.virt-manager-wrapped>": "î­»",
      "class<virtualbox manager>": "ًں’½",
      "title<virtualbox>": "ًں’½",
      "class<remmina>": "ًں–¥ï¸ڈ",
      "class<VSCode|code-url-handler|code-oss|codium|codium-url-handler|VSCodium>": "َ°¨‍",
      "class<dev.zed.Zed>": "َ°µپ",
      "class<codeblocks>": "َ°…©",
      "title<.*github.*>": "ï„“",
      "class<mousepad>": "ï…œ",
      "class<libreoffice-writer>": "îڑ¥",
      "class<libreoffice-startcenter>": " َ°ڈ†",
      "class<libreoffice-calc>": "ïچ»",
      "title<.*nvim ~.*>": "ïچ¯",
      "class<org.gnome.Nautilus>": "َ°£†",
      "title<.*vim.*>": "îں…",
      "title<.*figma.*>": "î½‡",
      "title<.*jira.*>": "î‌œ",
      "class<jetbrains-idea>": "î‍µ",
      "title<*.VSCode.*>": "َ°¨‍",
      "class<.*code.*>": "َ°¨‍",
      "class<obs|com.obsproject.Studio>": "î®§",
      "class<polkit-gnome-authentication-agent-1>": "َ°’ƒ",
      "class<nwg-look>": "î­’",
      "class<[Pp]avucontrol|org.pulseaudio.pavucontrol>": "َ±،«",
      "class<steam>": "ï†¶",
      "class<thunar|nemo>": "َ°‌°",	
      "class<Gparted>":"ïƒ‡",
      "class<gimp>": "ïŒ¸",
      "class<emulator>": "ًں“±",
      "class<android-studio>": "ï…»",
      "class<org.pipewire.Helvum>": "َ°“ƒ",
      "class<localsend>":"ï‡ ",
      "class<PrusaSlicer|UltiMaker-Cura|OrcaSlicer>": "َ°¹›"
    }
  },
  "idle_inhibitor": {
    "format": "{icon}",
    "format-icons": {
      "activated": "َ°›ٹ",
      "deactivated": "َ°¾ھ"
    }
  },
  "mpris": {
    "format": "َ°‹ژ {title}",
    "format-paused": "<i><span color='grey'>{status_icon} {artist}</span></i>",
    "max-length": 30,
    "player-icons": {
      "default": "âڈ¸",
      "mpv": "ًںژµ"
    },
    "status-icons": {
      "paused": "َ°‹گ"  
    },
    //"ignored-players": ["firefox", "chromium", "brave"]
  },
  "custom/updatespacman": {
    "format": "{}{icon}",
    "return-type": "json",
    "format-icons": {
      "has-updates": " َ°ڈ–",
      "updated": ""
    },
    "exec-if": "which waybar-module-pacman-updates",
    "exec": "waybar-module-pacman-updates --no-zero-output"
  },
  "custom/screenrecording-indicator": {
    "on-click": "omarchy-cmd-screenrecord",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/screen-recording.sh",
    "signal": 8,
    "return-type": "json"
  },
  "tray": {
    "icon-size": 11,
    "spacing": 5,
    "show-passive-items": true
  },

  // >>> Systems Widgets <<< //
  "network": {
    "format-icons": [
      "َ°¤¯",
      "َ°¤ں",
      "َ°¤¢",
      "َ°¤¥",
      "َ°¤¨"
    ],
    "format": "{icon}",
    "format-wifi": "{icon}",
    "format-ethernet": "َ°ˆ€",
    "format-disconnected": "َ°¤®",
    "tooltip-format-wifi": "{essid} ({frequency} GHz)\nâ‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-ethernet": "â‡£{bandwidthDownBytes}  â‡،{bandwidthUpBytes}",
    "tooltip-format-disconnected": "Disconnected",
    "interval": 3,
    "spacing": 1,
    "on-click": "omarchy-launch-wifi"
  },
  "battery": {
    "format": "{capacity}% {icon}",
    "format-discharging": "{capacity}% {icon}",
    "format-charging": "{capacity}% {icon}",
    "format-plugged": "ï‡¦",
    "format-icons": {
      "charging": [
        "َ°¢œ",
        "َ°‚†",
        "َ°‚‡",
        "َ°‚ˆ",
        "َ°¢‌",
        "َ°‚‰",
        "َ°¢‍",
        "َ°‚ٹ",
        "َ°‚‹",
        "َ°‚…"
      ],
      "default": [
        "َ°پ؛",
        "َ°پ»",
        "َ°پ¼",
        "َ°پ½",
        "َ°پ¾",
        "َ°پ؟",
        "َ°‚€",
        "َ°‚پ",
        "َ°‚‚",
        "َ°پ¹"
      ]
    },
    "format-full": "َ°‚… {capacity}%",
    "tooltip-format-discharging": "{timeTo}",
    "tooltip-format-charging": "{timeTo}",
    "interval": 5,
    "on-click": "omarchy-menu power",
    "states": {
      "warning": 20,
      "critical": 10
    }
  },
  "bluetooth": {
    "format": "ïٹ”",
    "format-disabled": "َ°‚²",
    "format-connected": "َ°‚±",
    "tooltip-format": "Devices connected: {num_connections}",
    "on-click": "omarchy-launch-bluetooth"
  },
  "pulseaudio#input": {
    "format-source": "ï„°",
    "format-source-muted": "ï„± ",
    "format": "{format_source}",
    "tooltip-format": "{format_source} {source_volume}%",
    "scroll-step": 1,
    "smooth-scrolling-threshold": 1,
    "max-volume": 100,
    "on-click": "omarchy-launch-or-focus-tui wiremix",
    "on-click-right": "pamixer -t",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +1%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -1%"
  },
  "pulseaudio#output": {
      "format": "{icon}",
      "tooltip-format": "{icon}  {volume}%",
      "format-muted": "ï€¦ off",
      "format-icons": {
          "default": ["ï€¥"]
      },
      "max-volume": 100,
      "scroll-step": 2,
      "smooth-scrolling-threshold": 1,
      "on-click": "omarchy-launch-or-focus-tui wiremix",
      "on-click-right": "pamixer -t"
  },
 "power-profiles-daemon": {
    "format": "{icon}",
    "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
    "tooltip": true,
    "format-icons": {
      "default": "َ°“…",
      "performance": "َ°“…",
      "balanced": "َ°¾…",
      "power-saver": "َ°¾†"
    }
  },
  "cpu": {
    "interval": 2,
    "format": "َ°چ› {usage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
    "memory": {
    "interval": 2,
    "format": "î‰¦ {percentage}%",
    "on-click": "omarchy-launch-or-focus-tui btop"
  },
   "backlight": {
    "device": "intel_backlight",
    "format": "{icon}",
    "tooltip-format": "{percent}%",
    "format-icons": [
      "ًںŒ‘",
      "ًںŒک",
      "ًںŒ—",
      "ًںŒ–",
      "ًںŒ•"
    ]
  },
  "clock": {
    "format": "{:%A %H:%M}",
    "format-alt": "{:L%d %B W%V %Y}",
    "tooltip-format": "<span>{calendar}</span>",
    "calendar": {
      "mode": "month",
      "mode-mon-col": 3,
      "on-click-right": "mode",
      "format": {
        "month": "<span color='#ffead3'><b>{}</b></span>",
        "weekdays": "<span color='#ffcc66'><b>{}</b></span>",
        "today": "<span color='#ff6699'><b>{}</b></span>"
      },
    },
    "on-click-right": "omarchy-launch-webapp https://calendar.google.com/calendar/u/0/r"
  },
}
