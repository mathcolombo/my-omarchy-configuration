{
  // >>> Properties <<< //
  "exclusive": true,
  "reload_style_on_change": true,
  "position": "top",
  "spacing": 0,
  "height": 27,
  "margin-top": 0,

  // >>> Modules Separators <<< //
  "modules-left": [
    "group/menu",
    "hyprland/window", 
    "group/music"
  ],
  "modules-center": [
    "hyprland/workspaces"
  ],
  "modules-right": [
    "group/tray-apps",
    "group/hardware",
    "group/system"
  ],

  // >>> Modules Groups <<< //
  "group/menu": {
    "orientation": "inherit",
    "modules": [
      "custom/omarchy",
      "clock",
      "custom/idle-indicator",
      "custom/notification-silencing-indicator",
      "custom/voxtype",
      "idle_inhibitor",
      "custom/screenrecording-indicator",
      "custom/updatespacman",
      "custom/update"
    ]
  },
  "group/music": {
    "orientation": "inherit",
    "modules": ["mpris"]
  },
  "group/system": {
    "orientation": "inherit",
    "modules": [
      "backlight",
      "power-profiles-daemon",
      "pulseaudio#output",
      "bluetooth",
      "network",
      "battery"
    ] 
  },
  "group/tray-apps": {
    "orientation": "inherit",
    "modules": ["tray"]
  },
  "group/hardware": {
    "orientation": "inherit",
    "modules": [
      "memory",
      "cpu"
    ]
  },

  // >>> Customs Widgets omarchy <<< //
  "custom/omarchy": {
    "format": "<span font='omarchy'>\ue900</span>",
    "on-click": "omarchy-menu",
    "on-click-right": "xdg-terminal-exec",
    "tooltip-format": "Omarchy Menu\n\nSuper + Alt + Space"
  },
  "custom/voxtype": {
    "exec": "omarchy-voxtype-status",
    "return-type": "json",
    "format": "{icon}",
    "format-icons": {
      "idle": "",
      "recording": "َ°چ¬",
      "transcribing": "َ°”ں"
    },
    "tooltip": true,
    "on-click-right": "omarchy-voxtype-config",
    "on-click": "omarchy-voxtype-model"
  },
  "custom/idle-indicator": {
    "on-click": "omarchy-toggle-idle",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/idle.sh",
    "signal": 9,
    "return-type": "json"
  },
  "custom/notification-silencing-indicator": {
    "on-click": "omarchy-toggle-notification-silencing",
    "exec": "$OMARCHY_PATH/default/waybar/indicators/notification-silencing.sh",
    "signal": 10,
    "return-type": "json"
  },
  "custom/update": {
    "format": "ï€،",
    "exec": "omarchy-update-available",
    "on-click": "omarchy-launch-floating-terminal-with-presentation omarchy-update",
    "tooltip-format": "Omarchy update available",
    "signal": 7,
    "interval": 21600
  },

  // >>> Others Widgets <<< //
  "hyprland/window": {
    "format": "{initialTitle}",
    "max-length": 25,
    "separate-outputs": true,
    "icon": true,
    "icon-size": 16, 
    "rewrite": {
        "^$": "َ°‡„ Desktop",
        "music.youtube.com(.*)": "َ±–ڈ Youtube Music",
        "web.whatsapp.com(.*)": "ïˆ² Whatsapp",
        "gemini.google.com(.*)": "î¸چ Gemini AI",
        "github.com(.*)": "îœ‰ Github",
        "calendar.google.com(.*)": "ï‘• Google Calendar",
        "contacts.google.com(.*)": "َ°›‹ Google Contacts"
    }
  },
  "hyprland/workspaces": {
    "persistent-workspaces": {"*": [ 1,2,3 ]},
    "on-click": "activate",
    "format": "{icon} {windows}",
    "format-icons": {
        "1": "خ±ج…",
        "2": "خ²ج…",
        "3": "خ³ج…",
        "4": "خ´ج…",
        "5": "خµج…",
        "6": "دƒد„ت¹",
        "7": "خ¶ج…",
        "8": "خ·ج…",
        "9": "خ¸ج…",
        "10": "خ¹ج…"
    },
    "format-window-separator": " ",
    "window-rewrite-default": "ïپ™",
    "window-rewrite": {		
      "class<.*imv*.>": "ï“¥",
      "class<.*bambustudio*.>": "َ°گ«",
      "class<.*bitwarden*.>": "î´¥",
      "class<.*handbrake*.>": "َ°ˆ«",
      "class<.*stremio*.>": "َ±–ڈ",
      "title<.*waydroid*.>": "îœژ",
      "class<.*grayjay*.>": "َ±—†",
      "title<.*amazon.*>": "ï‰°",
      "class<firefox|org.mozilla.firefox|librewolf|floorp|mercury-browser|[Cc]achy-browser>": "î‌…",
